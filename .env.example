# This file serves as a template for environment variables
# Copy this to .env and update with your actual configuration

# API Configuration
VITE_API_URL=http://localhost:3000

# Image paths
VITE_IMAGE_BASE_PATH=/photos
VITE_THUMBNAIL_SIZE=280x200

# Site Configuration
VITE_SITE_TITLE=Rex Benning Photography
VITE_SITE_DOMAIN=rexbenning.com

# Cloudflare Configuration (if using Cloudflare API)
VITE_CLOUDFLARE_ZONE_ID=
VITE_CLOUDFLARE_API_TOKEN=
